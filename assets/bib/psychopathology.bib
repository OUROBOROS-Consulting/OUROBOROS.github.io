	month = mar,
	year = {2025},
	keywords = {HiTOP, psychopathology, symptom-level, youth, Ouroboros},
	pages = {207--221},
	file = {Full Text:/Users/apostolos/Zotero/storage/WHF84I3Y/Forbes et al. - 2025 - A Hierarchical Model of the Symptom-Level Structure of Psychopathology in Youth.pdf:application/pdf},
}

